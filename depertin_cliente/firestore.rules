rules_version = '2';

// DiPertin — regras Firestore
// Deploy: .\firebase_deploy.ps1  ou  firebase deploy --only firestore:rules
//
// Perfis: master, master_city, lojista, cliente, entregador

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    function role() {
      return userExists()
        ? userData().get('role', userData().get('tipoUsuario', ''))
        : '';
    }

    function isMaster() {
      return userExists() && role() == 'master';
    }

    function isMasterCity() {
      return userExists() && role() == 'master_city';
    }

    function isStaff() {
      return isMaster() || isMasterCity();
    }

    function isEntregador() {
      return userExists() && role() == 'entregador';
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isStaff());
      allow delete: if isMaster();
    }

    match /pedidos/{pedidoId} {
      function p() {
        return resource.data;
      }

      function entregadorAtribuido() {
        return 'entregador_id' in p() && p().entregador_id == request.auth.uid;
      }

      function podeLerPedido() {
        return signedIn() && (
          p().cliente_id == request.auth.uid ||
          p().loja_id == request.auth.uid ||
          entregadorAtribuido() ||
          (isEntregador() && p().status in ['a_caminho', 'em_rota']) ||
          isStaff()
        );
      }

      allow read: if podeLerPedido();

      allow create: if signedIn()
        && request.resource.data.cliente_id == request.auth.uid;

      allow update: if signedIn() && (
        isStaff() ||
        p().loja_id == request.auth.uid ||
        p().cliente_id == request.auth.uid ||
        entregadorAtribuido() ||
        (isEntregador() && p().status in ['a_caminho', 'em_rota'])
      );

      allow delete: if isMaster();

      match /mensagens/{msgId} {
        function pedidoPai() {
          return get(/databases/$(database)/documents/pedidos/$(pedidoId)).data;
        }

        allow read: if signedIn() && (
          pedidoPai().cliente_id == request.auth.uid ||
          pedidoPai().loja_id == request.auth.uid ||
          isStaff()
        );
        allow create: if signedIn() && (
          pedidoPai().cliente_id == request.auth.uid ||
          pedidoPai().loja_id == request.auth.uid ||
          isStaff()
        );
        allow update, delete: if isStaff();
      }
    }

    match /produtos/{id} {
      allow read: if true;
      allow create: if signedIn() && (
        request.resource.data.lojista_id == request.auth.uid ||
        request.resource.data.loja_id == request.auth.uid
      );
      allow update, delete: if signedIn() && (
        ('lojista_id' in resource.data && resource.data.lojista_id == request.auth.uid) ||
        ('loja_id' in resource.data && resource.data.loja_id == request.auth.uid) ||
        isStaff()
      );
    }

    match /categorias/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /sugestoes_categorias/{id} {
      allow read: if signedIn();
      allow write: if isStaff();
    }

    match /banners/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /avaliacoes/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isStaff()
        || ('cliente_id' in resource.data && resource.data.cliente_id == request.auth.uid);
    }

    match /gateways_pagamento/{id} {
      allow read: if signedIn();
      allow write: if isStaff();
    }

    match /planos_taxas/{id} {
      allow read: if signedIn();
      allow write: if isStaff();
    }

    match /tabela_fretes/{id} {
      allow read: if signedIn();
      allow write: if isStaff();
    }

    match /receitas_app/{id} {
      allow read, write: if isStaff();
    }

    match /saques_solicitacoes/{id} {
      allow read: if signedIn() && (
        isStaff() ||
        ('user_id' in resource.data && resource.data.user_id == request.auth.uid)
      );
      allow create: if signedIn();
      allow update, delete: if isStaff();
    }

    match /vagas/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isStaff()
        || ('criador_id' in resource.data && resource.data.criador_id == request.auth.uid);
    }

    match /achados/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isStaff()
        || ('criador_id' in resource.data && resource.data.criador_id == request.auth.uid);
    }

    match /eventos/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isStaff()
        || ('criador_id' in resource.data && resource.data.criador_id == request.auth.uid);
    }

    match /telefones_premium/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /servicos_destaque/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /suporte/{ticketId} {
      // Legado — mantido para histórico; novos atendimentos usam support_tickets
      allow read: if signedIn() && (
        isStaff() ||
        ('user_id' in resource.data && resource.data.user_id == request.auth.uid) ||
        ('cliente_id' in resource.data && resource.data.cliente_id == request.auth.uid)
      );
      allow create: if signedIn();
      allow update: if signedIn() && (
        isStaff() ||
        ('user_id' in resource.data && resource.data.user_id == request.auth.uid) ||
        ('cliente_id' in resource.data && resource.data.cliente_id == request.auth.uid)
      );

      match /mensagens/{msgId} {
        function ticketLegado() {
          return get(/databases/$(database)/documents/suporte/$(ticketId)).data;
        }

        allow read: if signedIn() && (
          isStaff() ||
          ('user_id' in ticketLegado() && ticketLegado().user_id == request.auth.uid) ||
          ('cliente_id' in ticketLegado() && ticketLegado().cliente_id == request.auth.uid)
        );
        allow create: if signedIn();
        allow update, delete: if isStaff();
      }
    }

    // Central de Ajuda — protocolo, fila e mensagens (modelo atual).
    // Push para o cliente: Cloud Functions (Admin SDK) em criação do ticket,
    // nova mensagem do atendente (sender_type agent) e encerramento (closed + closed_by support).
    match /support_tickets/{ticketId} {
      function ticketOwner() {
        return signedIn() && resource.data.user_id == request.auth.uid;
      }

      function ticketCreateOwner() {
        return signedIn() && request.resource.data.user_id == request.auth.uid;
      }

      allow read: if isStaff() || ticketOwner();

      allow create: if ticketCreateOwner()
        && request.resource.data.protocol_number is int
        && request.resource.data.protocol_number >= 10000000
        && request.resource.data.protocol_number <= 99999999
        && request.resource.data.status == 'waiting'
        && request.resource.data.keys().hasAll([
          'protocol_number', 'user_id', 'user_nome', 'cidade', 'status',
          'created_at', 'updated_at'
        ]);

      // Cliente: pode cancelar ou atualizar prévia/updated_at; não pode assumir atendimento
      allow update: if isStaff() || (
        ticketOwner()
        && request.resource.data.user_id == resource.data.user_id
        && request.resource.data.protocol_number == resource.data.protocol_number
        && request.resource.data.created_at == resource.data.created_at
        && request.resource.data.agent_id == resource.data.agent_id
        && request.resource.data.agent_nome == resource.data.agent_nome
        && (
          !('started_at' in resource.data)
          || request.resource.data.started_at == resource.data.started_at
        )
        && (
          request.resource.data.status == resource.data.status
          || (
            request.resource.data.status == 'cancelled'
            && resource.data.status in ['waiting', 'in_progress']
          )
        )
        && !(
          resource.data.status == 'waiting'
          && request.resource.data.status == 'in_progress'
        )
        && (
          request.resource.data.status == 'cancelled'
          || (
            request.resource.data.finished_at == resource.data.finished_at
            && (
              !('closed_by' in resource.data)
              || request.resource.data.closed_by == resource.data.closed_by
            )
          )
        )
      );

      match /mensagens/{msgId} {
        function ticketAtual() {
          return get(/databases/$(database)/documents/support_tickets/$(ticketId)).data;
        }

        allow read: if isStaff() || (
          signedIn() && ticketAtual().user_id == request.auth.uid
        );

        allow create: if signedIn() && (
          (
            isStaff()
            && ticketAtual().status == 'in_progress'
            && ticketAtual().agent_id == request.auth.uid
            && request.resource.data.sender_type in ['agent', 'system']
          )
          || (
            ticketAtual().user_id == request.auth.uid
            && ticketAtual().status in ['waiting', 'in_progress']
            && request.resource.data.sender_type == 'client'
          )
        )
        && request.resource.data.keys().hasAll([
          'mensagem', 'sender_id', 'sender_type', 'created_at'
        ]);

        allow update, delete: if isStaff();
      }
    }

    match /support_ratings/{ratingId} {
      allow read: if isStaff() || (
        signedIn()
        && resource.data.user_id == request.auth.uid
      );
      allow create: if signedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.keys().hasAll([
          'ticket_id', 'user_id', 'rating', 'created_at'
        ]);
      allow update, delete: if isStaff();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Recuperação de senha — apenas Cloud Functions (Admin SDK)
    match /password_reset_tokens/{id} {
      allow read, write: if false;
    }
    match /password_reset_rate_email/{id} {
      allow read, write: if false;
    }
    match /password_reset_rate_ip/{id} {
      allow read, write: if false;
    }

    match /{document=**} {
      // Staff, exceto dados sensíveis de recuperação de senha (só Admin SDK)
      allow read, write: if isStaff()
        && !request.path.matches('databases/{database}/documents/password_reset_tokens/{docId}')
        && !request.path.matches('databases/{database}/documents/password_reset_rate_email/{docId}')
        && !request.path.matches('databases/{database}/documents/password_reset_rate_ip/{docId}');
    }
  }
}
